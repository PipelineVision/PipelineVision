# ===================
# PRODUCTION API
# ===================
api.pipelinevision.app {
    @sse path /api/v1/events*
    reverse_proxy @sse backend:8000 {
        header_up Host {host}
        header_up X-Real-IP {remote}
        flush_interval -1
    }

    reverse_proxy backend:8000 {
        header_up Host {host}
        header_up X-Real-IP {remote}
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        X-XSS-Protection "1; mode=block"
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-eval' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://avatars.githubusercontent.com; font-src 'self' data:; connect-src 'self' https://api.pipelinevision.app https://api.github.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
    }

    @notsse not path /api/v1/events*
    encode @notsse gzip
}

# ===================
# DEVELOPMENT API
# ===================
dev-api.pipelinevision.app {
    @sse path /api/v1/events*
    reverse_proxy @sse backend-dev:8000 {
        header_up Host {host}
        header_up X-Real-IP {remote}
        flush_interval -1
    }

    reverse_proxy backend-dev:8000 {
        header_up Host {host}
        header_up X-Real-IP {remote}
    }

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        X-XSS-Protection "1; mode=block"
    }

    @notsse_dev not path /api/v1/events*
    encode @notsse_dev gzip
}
